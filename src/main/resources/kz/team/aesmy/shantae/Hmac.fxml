<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="480.0" prefWidth="660.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kz.team.aesmy.shantae.Controller.HmacController">
  <children>

    <MenuBar>
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
            <MenuItem mnemonicParsing="false" text="Import input"  onAction="#onImport"/>
            <MenuItem mnemonicParsing="false" text="Export output" onAction="#onExport"/>
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="-1.0"
                minHeight="-Infinity" minWidth="-Infinity"
                prefHeight="450.0" prefWidth="660.0" VBox.vgrow="ALWAYS">
      <children>

        <!-- Key -->
        <Label layoutX="18.0" layoutY="6.0" text="Key">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TextArea fx:id="keyArea"
                  layoutX="18.0" layoutY="22.0"
                  prefHeight="60.0" prefWidth="460.0"
                  promptText="Secret key (text or hex)" wrapText="true">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </TextArea>
        <CheckBox fx:id="hexKeyBox"
                  layoutX="490.0" layoutY="22.0"
                  text="Hex input" mnemonicParsing="false">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </CheckBox>

        <!-- Message -->
        <Label layoutX="18.0" layoutY="96.0" text="Message">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TextArea fx:id="messageArea"
                  layoutX="18.0" layoutY="112.0"
                  prefHeight="100.0" prefWidth="460.0"
                  promptText="Message text or file content" wrapText="true">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </TextArea>
        <Button layoutX="490.0" layoutY="112.0"
                prefHeight="25.0" prefWidth="130.0"
                text="Browse File" mnemonicParsing="false"
                onAction="#onBrowseFile">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>

        <!-- Tag output -->
        <Label layoutX="18.0" layoutY="226.0" text="HMAC Tag">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TextArea fx:id="tagArea"
                  layoutX="18.0" layoutY="242.0"
                  prefHeight="60.0" prefWidth="460.0"
                  promptText="Computed tag / paste tag to verify" wrapText="true">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </TextArea>
        <Button layoutX="490.0" layoutY="242.0"
                prefHeight="25.0" prefWidth="130.0"
                text="Copy Tag" mnemonicParsing="false"
                onAction="#onCopy">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>

        <!-- Verify result label -->
        <Label fx:id="verifyLabel" layoutX="490.0" layoutY="280.0" text="">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Label>

        <!-- Action buttons -->
        <Button layoutX="133.0" layoutY="390.0"
                prefHeight="25.0" prefWidth="110.0"
                text="Generate Tag" mnemonicParsing="false"
                onAction="#onGenerate">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>
        <Button layoutX="263.0" layoutY="390.0"
                prefHeight="25.0" prefWidth="110.0"
                text="Verify Tag" mnemonicParsing="false"
                onAction="#onVerify">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>
        <Button layoutX="393.0" layoutY="390.0"
                prefHeight="25.0" prefWidth="85.0"
                text="Clear" mnemonicParsing="false"
                onAction="#onClear">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>

      </children>
    </AnchorPane>
  </children>
</VBox>

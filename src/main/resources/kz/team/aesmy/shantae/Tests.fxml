<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="480.0" prefWidth="660.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kz.team.aesmy.shantae.Controller.TestsController">
  <children>

    <MenuBar>
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
            <MenuItem mnemonicParsing="false" text="Export results" onAction="#onExport"/>
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="-1.0"
                minHeight="-Infinity" minWidth="-Infinity"
                prefHeight="450.0" prefWidth="660.0" VBox.vgrow="ALWAYS">
      <children>

        <!-- Section label: Functional Tests -->
        <Label layoutX="18.0" layoutY="8.0" text="── Functional Tests ──────────────────────────">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>

        <!-- Functional test buttons -->
        <Button layoutX="18.0"  layoutY="28.0" prefHeight="25.0" prefWidth="160.0"
                text="Collision Resistance" mnemonicParsing="false"
                onAction="#onCollision">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="190.0" layoutY="28.0" prefHeight="25.0" prefWidth="160.0"
                text="Avalanche Effect" mnemonicParsing="false"
                onAction="#onAvalanche">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>

        <Button layoutX="18.0"  layoutY="62.0" prefHeight="25.0" prefWidth="160.0"
                text="HMAC Verify" mnemonicParsing="false"
                onAction="#onHmacVerify">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="190.0" layoutY="62.0" prefHeight="25.0" prefWidth="160.0"
                text="Password Storage" mnemonicParsing="false"
                onAction="#onPasswordStorage">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="362.0" layoutY="62.0" prefHeight="25.0" prefWidth="160.0"
                text="Different Salts" mnemonicParsing="false"
                onAction="#onDifferentSalts">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>

        <Button layoutX="534.0" layoutY="28.0" prefHeight="25.0" prefWidth="100.0"
                text="Run All Tests" mnemonicParsing="false"
                onAction="#onRunAllTests">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>

        <!-- Section label: Benchmarks -->
        <Label layoutX="18.0" layoutY="100.0" text="── Performance Benchmarks ────────────────────">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>

        <!-- Benchmark buttons -->
        <Button layoutX="18.0"  layoutY="120.0" prefHeight="25.0" prefWidth="150.0"
                text="SHA-256 Speed" mnemonicParsing="false"
                onAction="#onBenchSHA256">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="180.0" layoutY="120.0" prefHeight="25.0" prefWidth="150.0"
                text="HMAC Speed" mnemonicParsing="false"
                onAction="#onBenchHMAC">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="342.0" layoutY="120.0" prefHeight="25.0" prefWidth="160.0"
                text="PBKDF2 (100k iterations)" mnemonicParsing="false"
                onAction="#onBenchPBKDF2">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>
        <Button layoutX="514.0" layoutY="120.0" prefHeight="25.0" prefWidth="120.0"
                text="File Hash Speed" mnemonicParsing="false"
                onAction="#onBenchFileHash">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>

        <Button layoutX="534.0" layoutY="62.0" prefHeight="25.0" prefWidth="100.0"
                text="Run All Benchmarks" mnemonicParsing="false"
                onAction="#onRunAllBench">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Button>

        <!-- Results output -->
        <Label layoutX="18.0" layoutY="158.0" text="Results">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TextArea fx:id="resultsArea"
                  layoutX="18.0" layoutY="174.0"
                  prefHeight="248.0" prefWidth="624.0"
                  editable="false" wrapText="true">
          <font><Font name="Fira Code Regular" size="11.0"/></font>
        </TextArea>

        <!-- Clear button -->
        <Button layoutX="300.0" layoutY="432.0"
                prefHeight="25.0" prefWidth="85.0"
                text="Clear" mnemonicParsing="false"
                onAction="#onClear">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>

      </children>
    </AnchorPane>
  </children>
</VBox>

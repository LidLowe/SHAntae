<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="480.0" prefWidth="660.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kz.team.aesmy.shantae.Controller.PasswordController">
  <children>

    <MenuBar>
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
            <MenuItem mnemonicParsing="false" text="Export passwords" onAction="#onExport"/>
            <MenuItem mnemonicParsing="false" text="Import passwords" onAction="#onImport"/>
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="-1.0"
                minHeight="-Infinity" minWidth="-Infinity"
                prefHeight="450.0" prefWidth="660.0" VBox.vgrow="ALWAYS">
      <children>

        <!-- Username -->
        <Label layoutX="18.0" layoutY="10.0" text="Username">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TextField fx:id="usernameField"
                   layoutX="18.0" layoutY="28.0"
                   prefHeight="28.0" prefWidth="400.0"
                   promptText="Enter username">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </TextField>

        <!-- Password -->
        <Label layoutX="18.0" layoutY="66.0" text="Password">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <PasswordField fx:id="passwordField"
                       layoutX="18.0" layoutY="84.0"
                       prefHeight="28.0" prefWidth="400.0"
                       promptText="Enter password">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </PasswordField>

        <!-- Status feedback -->
        <TextArea fx:id="statusArea"
                  layoutX="18.0" layoutY="128.0"
                  prefHeight="50.0" prefWidth="612.0"
                  promptText="Status" editable="false" wrapText="true">
          <font><Font name="Fira Code Regular" size="11.0"/></font>
        </TextArea>

        <!-- Stored entries table -->
        <Label layoutX="18.0" layoutY="190.0" text="Stored Entries">
          <font><Font name="Fira Code Regular" size="12.0"/></font>
        </Label>
        <TableView fx:id="passwordTable"
                   layoutX="18.0" layoutY="208.0"
                   prefHeight="180.0" prefWidth="612.0">
          <columns>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="160.0"/>
            <TableColumn fx:id="colSalt"     text="Salt (hex)" prefWidth="200.0"/>
            <TableColumn fx:id="colHash"     text="Hash (hex)" prefWidth="250.0"/>
          </columns>
        </TableView>

        <!-- Action buttons -->
        <Button layoutX="133.0" layoutY="406.0"
                prefHeight="25.0" prefWidth="120.0"
                text="Store Password" mnemonicParsing="false"
                onAction="#onStore">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>
        <Button layoutX="273.0" layoutY="406.0"
                prefHeight="25.0" prefWidth="130.0"
                text="Verify Password" mnemonicParsing="false"
                onAction="#onVerify">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>
        <Button layoutX="423.0" layoutY="406.0"
                prefHeight="25.0" prefWidth="85.0"
                text="Delete" mnemonicParsing="false"
                onAction="#onDelete">
          <font><Font name="Fira Code Regular" size="13.0"/></font>
        </Button>

      </children>
    </AnchorPane>
  </children>
</VBox>
